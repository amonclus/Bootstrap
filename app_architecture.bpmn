<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://app-architecture" exporter="Camunda Modeler" exporterVersion="5.46.0">
  <collaboration id="Collaboration_1">
    <participant id="Pool_app" name="app.py — Network Contagion Lab&#10;(Research / Simulation UI)" processRef="Process_app" />
    <participant id="Pool_app2" name="app2.py — ViralSense&#10;(Virality Predictor)" processRef="Process_app2" />
    <participant id="Pool_mlpipeline" name="ML Training Pipeline&#10;(ml_scripts/ml_analysis.py)" processRef="Process_mlpipeline" />
    <messageFlow id="MF_sim_to_ml" name="50 000 labelled&#10;time-series rows" sourceRef="Task_save_csv" targetRef="Task_train_ml" />
    <messageFlow id="MF_ml_to_app2" name="Trained .pkl files" sourceRef="Task_save_pkl" targetRef="Task_load_models" />
  </collaboration>
  <process id="Process_app" isExecutable="false">
    <sequenceFlow sourceRef="SE_app" targetRef="Task_app_entry" />
    <sequenceFlow sourceRef="Task_app_entry" targetRef="GW_model_selected" />
    <sequenceFlow sourceRef="Task_welcome" targetRef="EE_app" />
    <sequenceFlow sourceRef="Task_render_sidebar" targetRef="Task_load_graph" />
    <sequenceFlow sourceRef="Task_load_graph" targetRef="GW_model_dispatch" />
    <sequenceFlow sourceRef="SP_base_models" targetRef="EE_app" />
    <sequenceFlow sourceRef="SP_hybrid_models" targetRef="EE_app" />
    <startEvent id="SE_app" name="streamlit run src/app.py">
      <outgoing>Flow_0yina7f</outgoing>
    </startEvent>
    <task id="Task_app_entry" name="app_entry.run_app()&#10;(app_entry.py)">
      <incoming>Flow_0yina7f</incoming>
      <outgoing>Flow_01uettc</outgoing>
    </task>
    <exclusiveGateway id="GW_model_selected" name="MODEL in&#10;session_state?">
      <incoming>Flow_01uettc</incoming>
    </exclusiveGateway>
    <task id="Task_welcome" name="_render_welcome()&#10;Show 10 model cards&#10;with selection buttons">
      <outgoing>Flow_1i2oumt</outgoing>
    </task>
    <task id="Task_render_sidebar" name="render_sidebar(model)&#10;(sidebar.py)&#10;Graph source + parameters">
      <outgoing>Flow_0znlsxo</outgoing>
    </task>
    <task id="Task_load_graph" name="get_graph_or_stop()&#10;Load / generate graph&#10;(graph_loader.py)">
      <incoming>Flow_0znlsxo</incoming>
      <incoming>Flow_1i2oumt</incoming>
      <outgoing>Flow_1riw2jm</outgoing>
    </task>
    <exclusiveGateway id="GW_model_dispatch" name="model?">
      <incoming>Flow_1riw2jm</incoming>
    </exclusiveGateway>
    <subProcess id="SP_base_models" name="Base Models&#10;Bootstrap / SIR / SIS / WTM">
      <outgoing>Flow_1gziido</outgoing>
      <startEvent id="SE_base" />
      <task id="Task_base_tabs" name="5 tabs per model:&#10;📊 Graph Stats&#10;🔬 Simulation&#10;🎬 Animation&#10;🎯 Vulnerability&#10;📈 Parameter Sweep" />
      <endEvent id="EE_base" />
      <sequenceFlow sourceRef="SE_base" targetRef="Task_base_tabs" />
      <sequenceFlow sourceRef="Task_base_tabs" targetRef="EE_base" />
    </subProcess>
    <subProcess id="SP_hybrid_models" name="Hybrid Models&#10;H1 / H2 / H3 / H4 / H5 / H6">
      <outgoing>Flow_0s3bb05</outgoing>
      <startEvent id="SE_hybrid" />
      <task id="Task_hybrid_tabs" name="5 tabs per model:&#10;📊 Graph Stats&#10;🔬 Simulation&#10;🎬 Animation&#10;🎯 Vulnerability&#10;📈 Parameter Sweep" />
      <task id="Task_save_csv" name="Save results as CSV&#10;(experiments/results/{model}/)" />
      <endEvent id="EE_hybrid" />
      <sequenceFlow sourceRef="SE_hybrid" targetRef="Task_hybrid_tabs" />
      <sequenceFlow sourceRef="Task_hybrid_tabs" targetRef="Task_save_csv" />
      <sequenceFlow sourceRef="Task_save_csv" targetRef="EE_hybrid" />
    </subProcess>
    <endEvent id="EE_app" name="Await next interaction">
      <incoming>Flow_1gziido</incoming>
      <incoming>Flow_0s3bb05</incoming>
    </endEvent>
    <sequenceFlow id="Flow_0yina7f" sourceRef="SE_app" targetRef="Task_app_entry" />
    <sequenceFlow id="Flow_01uettc" sourceRef="Task_app_entry" targetRef="GW_model_selected" />
    <sequenceFlow id="SF_no_model" name="No" sourceRef="GW_model_selected" targetRef="Task_welcome" />
    <sequenceFlow id="SF_has_model" name="Yes" sourceRef="GW_model_selected" targetRef="Task_render_sidebar" />
    <sequenceFlow id="Flow_1i2oumt" sourceRef="Task_welcome" targetRef="Task_load_graph" />
    <sequenceFlow id="Flow_0znlsxo" sourceRef="Task_render_sidebar" targetRef="Task_load_graph" />
    <sequenceFlow id="Flow_1riw2jm" sourceRef="Task_load_graph" targetRef="GW_model_dispatch" />
    <sequenceFlow id="SF_base" name="Bootstrap/SIR/SIS/WTM" sourceRef="GW_model_dispatch" targetRef="SP_base_models" />
    <sequenceFlow id="SF_hybrid" name="H1–H6" sourceRef="GW_model_dispatch" targetRef="SP_hybrid_models" />
    <sequenceFlow id="Flow_1gziido" sourceRef="SP_base_models" targetRef="EE_app" />
    <sequenceFlow id="Flow_0s3bb05" sourceRef="SP_hybrid_models" targetRef="EE_app" />
  </process>
  <process id="Process_mlpipeline" isExecutable="false">
    <sequenceFlow sourceRef="SE_ml" targetRef="Task_run_sims" />
    <sequenceFlow sourceRef="Task_run_sims" targetRef="Task_extract_feats" />
    <sequenceFlow sourceRef="Task_extract_feats" targetRef="Task_train_ml" />
    <sequenceFlow sourceRef="Task_train_ml" targetRef="Task_save_pkl" />
    <sequenceFlow sourceRef="Task_save_pkl" targetRef="Task_write_summary" />
    <sequenceFlow sourceRef="Task_write_summary" targetRef="EE_ml" />
    <startEvent id="SE_ml" name="python ml_scripts/ml_analysis.py" />
    <task id="Task_run_sims" name="Run simulations across&#10;all 10 models × 5 networks&#10;(50 000 trajectories)" />
    <task id="Task_extract_feats" name="Extract 22 time-series&#10;features per trajectory" />
    <task id="Task_train_ml" name="Train RF Regressor (reach)&#10;+ RF Classifier (model ID)" />
    <task id="Task_save_pkl" name="Persist models to&#10;ml_data/*.pkl" />
    <task id="Task_write_summary" name="Write results/ml/summary.txt&#10;(MAE + accuracy)" />
    <endEvent id="EE_ml" name="ML artefacts ready" />
  </process>
  <process id="Process_app2" isExecutable="false">
    <sequenceFlow sourceRef="SE_app2" targetRef="Task_page_config" />
    <sequenceFlow sourceRef="Task_page_config" targetRef="Task_load_models" />
    <sequenceFlow sourceRef="Task_load_models" targetRef="GW_demo_mode" />
    <sequenceFlow sourceRef="Task_demo_mode_flag" targetRef="Task_render_tabs_entry" />
    <sequenceFlow sourceRef="Task_real_mode_flag" targetRef="Task_render_tabs_entry" />
    <sequenceFlow sourceRef="Task_render_tabs_entry" targetRef="SP_tab1" />
    <sequenceFlow sourceRef="Task_render_tabs_entry" targetRef="SP_tab2" />
    <sequenceFlow sourceRef="Task_render_tabs_entry" targetRef="SP_tab3" />
    <sequenceFlow sourceRef="SP_tab1" targetRef="EE_app2" />
    <sequenceFlow sourceRef="SP_tab2" targetRef="EE_app2" />
    <sequenceFlow sourceRef="SP_tab3" targetRef="EE_app2" />
    <startEvent id="SE_app2" name="streamlit run app2.py" />
    <task id="Task_page_config" name="Page config + CSS&#10;Dark theme, verdict styles" />
    <task id="Task_load_models" name="load_models() @cache_resource&#10;Load rf_regressor, rf_classifier,&#10;label_encoder, feature_names" />
    <exclusiveGateway id="GW_demo_mode" name="pkl files&#10;found?" />
    <task id="Task_demo_mode_flag" name="Set demo_mode=True&#10;(heuristic predictions only)" />
    <task id="Task_real_mode_flag" name="Set demo_mode=False&#10;(full ML predictions)" />
    <task id="Task_render_tabs_entry" name="Render 3 tabs" />
    <subProcess id="SP_tab1" name="Tab 1 — Will It Go Viral?&#10;render_tab1()">
      <startEvent id="SE_t1" />
      <task id="Task_sidebar_inputs" name="Sidebar inputs:&#10;• Content type&#10;• Network type&#10;• Input method (manual/upload/simulate)&#10;• Prediction horizon&#10;• [Predict Virality] button" />
      <exclusiveGateway id="GW_predict_clicked" name="Predict&#10;button&#10;clicked?" />
      <task id="Task_preview" name="Show early spread&#10;data preview chart" />
      <task id="Task_parse_input" name="Parse / validate input series&#10;_parse_upload() if CSV" />
      <task id="Task_run_prediction" name="run_prediction()&#10;→ extract_features() (22 features)&#10;→ build_feature_row()&#10;→ reg.predict() → rho_final&#10;→ clf.predict() → model_name&#10;→ generate_trajectory()" />
      <exclusiveGateway id="GW_demo_branch" name="demo_mode?" />
      <task id="Task_demo_predict" name="demo_predict()&#10;Heuristic rho + model" />
      <task id="Task_ml_predict" name="RF regressor + classifier&#10;predict reach + mechanism" />
      <task id="Task_render_verdict" name="Render verdict block:&#10;VIRAL / Strong / Moderate / Niche&#10;+ predicted reach %" />
      <task id="Task_render_mechanism" name="Render mechanism card:&#10;Model name, icon, description&#10;+ confidence %" />
      <task id="Task_render_trajectory" name="Render trajectory chart:&#10;Observed + predicted + band" />
      <task id="Task_render_tipping" name="Render tipping point analysis:&#10;Crossed? / Gap + hours estimate" />
      <task id="Task_export" name="Export panel:&#10;Text summary + CSV download" />
      <endEvent id="EE_t1" />
      <sequenceFlow sourceRef="SE_t1" targetRef="Task_sidebar_inputs" />
      <sequenceFlow sourceRef="Task_sidebar_inputs" targetRef="GW_predict_clicked" />
      <sequenceFlow id="SF_no_predict" name="No" sourceRef="GW_predict_clicked" targetRef="Task_preview" />
      <sequenceFlow id="SF_yes_predict" name="Yes" sourceRef="GW_predict_clicked" targetRef="Task_parse_input" />
      <sequenceFlow sourceRef="Task_preview" targetRef="EE_t1" />
      <sequenceFlow sourceRef="Task_parse_input" targetRef="Task_run_prediction" />
      <sequenceFlow sourceRef="Task_run_prediction" targetRef="GW_demo_branch" />
      <sequenceFlow id="SF_demo" name="Yes" sourceRef="GW_demo_branch" targetRef="Task_demo_predict" />
      <sequenceFlow id="SF_ml" name="No" sourceRef="GW_demo_branch" targetRef="Task_ml_predict" />
      <sequenceFlow sourceRef="Task_demo_predict" targetRef="Task_render_verdict" />
      <sequenceFlow sourceRef="Task_ml_predict" targetRef="Task_render_verdict" />
      <sequenceFlow sourceRef="Task_render_verdict" targetRef="Task_render_mechanism" />
      <sequenceFlow sourceRef="Task_render_mechanism" targetRef="Task_render_trajectory" />
      <sequenceFlow sourceRef="Task_render_trajectory" targetRef="Task_render_tipping" />
      <sequenceFlow sourceRef="Task_render_tipping" targetRef="Task_export" />
      <sequenceFlow sourceRef="Task_export" targetRef="EE_t1" />
    </subProcess>
    <subProcess id="SP_tab2" name="Tab 2 — How Does It Spread?&#10;render_tab2()">
      <startEvent id="SE_t2" />
      <task id="Task_two_types" name="Section: Two types of viral content&#10;Simple contagion vs Complex contagion&#10;(static charts)" />
      <task id="Task_interactive" name="Interactive slider demo&#10;k = 1..5 → curve shape changes" />
      <task id="Task_examples" name="Real-world examples panel&#10;(Breaking News / Ice Bucket / Vaccine)" />
      <task id="Task_tipping_chart" name="Tipping point illustration&#10;seeds vs final reach" />
      <endEvent id="EE_t2" />
      <sequenceFlow sourceRef="SE_t2" targetRef="Task_two_types" />
      <sequenceFlow sourceRef="Task_two_types" targetRef="Task_interactive" />
      <sequenceFlow sourceRef="Task_interactive" targetRef="Task_examples" />
      <sequenceFlow sourceRef="Task_examples" targetRef="Task_tipping_chart" />
      <sequenceFlow sourceRef="Task_tipping_chart" targetRef="EE_t2" />
    </subProcess>
    <subProcess id="SP_tab3" name="Tab 3 — About&#10;render_tab3()">
      <startEvent id="SE_t3" />
      <task id="Task_what_is" name="What is this? — thesis context" />
      <task id="Task_models_table" name="Models table&#10;(all 10 model names + types)" />
      <task id="Task_accuracy" name="Accuracy metrics&#10;_load_summary_metrics()&#10;from results/ml/summary.txt" />
      <task id="Task_limitations" name="Limitations + credits" />
      <endEvent id="EE_t3" />
      <sequenceFlow sourceRef="SE_t3" targetRef="Task_what_is" />
      <sequenceFlow sourceRef="Task_what_is" targetRef="Task_models_table" />
      <sequenceFlow sourceRef="Task_models_table" targetRef="Task_accuracy" />
      <sequenceFlow sourceRef="Task_accuracy" targetRef="Task_limitations" />
      <sequenceFlow sourceRef="Task_limitations" targetRef="EE_t3" />
    </subProcess>
    <endEvent id="EE_app2" name="Await next interaction" />
    <sequenceFlow id="SF_no_pkl" name="No" sourceRef="GW_demo_mode" targetRef="Task_demo_mode_flag" />
    <sequenceFlow id="SF_yes_pkl" name="Yes" sourceRef="GW_demo_mode" targetRef="Task_real_mode_flag" />
  </process>
